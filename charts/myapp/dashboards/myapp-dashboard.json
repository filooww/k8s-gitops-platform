{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "schemaVersion": 39,
  "uid": "myapp-fastapi",
  "title": "myapp / FastAPI service",
  "tags": ["myapp", "gitops"],
  "time": { "from": "now-30m", "to": "now" },
  "refresh": "10s",
  "templating": { "list": [] },
  "panels": [
    {
      "type": "timeseries",
      "title": "Request rate (req/s) by path",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[1m])) by (path)",
          "legendFormat": "{{path}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Latency p95 / p50 (s)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "B"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Error rate (5xx %)",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.05 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "(sum(rate(http_requests_total{status=~\"5..\"}[5m])) or vector(0)) / clamp_min(sum(rate(http_requests_total[5m])), 1)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "In-flight requests",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        { "expr": "sum(http_requests_in_flight)", "legendFormat": "in-flight", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Ready pods (HPA scaling)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum(kube_deployment_status_replicas_ready{deployment=~\".*myapp.*\"})",
          "legendFormat": "ready replicas",
          "refId": "A"
        }
      ]
    }
  ]
}
